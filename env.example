# ── Core ─────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
BYPASS_TOOL_CONSENT=true

# ── Per-agent models (leave empty to use MODEL_ID as fallback) ──────
RESEARCHER_MODEL_ID=
ANALYST_MODEL_ID=
WRITER_MODEL_ID=

# ── Specialized agent models (leave empty to use MODEL_ID as fallback)
# Used when ENABLE_MULTI_AGENT=true for domain-specific routing
ROUTER_MODEL_ID=
CATALOGO_MODEL_ID=
COMPLEMENTARIOS_MODEL_ID=
COTIZACION_MODEL_ID=
GENERAL_MODEL_ID=

# ── Feature flags (set to "true" to enable) ──────────────────────────
ENABLE_MCP=false
ENABLE_MULTI_AGENT=false
ENABLE_EXPRESS_AGENT=false
ENABLE_WEB_SEARCH=false
ENABLE_MEMORY=false
ENABLE_KNOWLEDGE_BASE=false
ENABLE_BROWSER=false
ENABLE_THINKING=false
ENABLE_ATHENA=false
ENABLE_CART=false

# ── Thinking (when ENABLE_THINKING=true) ─────────────────────────────
THINKING_BUDGET=4096

# ── MCP (when ENABLE_MCP=true) ──────────────────────────────────────
MCP_TRANSPORT=stdio
MCP_COMMAND=uvx
MCP_ARGS=awslabs.aws-documentation-mcp-server@latest
MCP_HTTP_URL=http://localhost:8000/mcp

# ── Memory (when ENABLE_MEMORY=true) ────────────────────────────────
MEMORY_ID=
MEMORY_ACTOR_ID=default-actor

# ── Knowledge Base (when ENABLE_KNOWLEDGE_BASE=true) ────────────────
KNOWLEDGE_BASE_ID=
KNOWLEDGE_BASE_REGION=us-east-1

# ── Browser (when ENABLE_BROWSER=true) ──────────────────────────────
BROWSER_START_URL=https://www.google.com/

# ── Athena (when ENABLE_ATHENA=true) ────────────────────────────────
ATHENA_LAMBDA_NAME=api-query-athena
ATHENA_LAMBDA_REGION=us-east-1

# ── Product List (when ENABLE_CART=true) ─────────────────────────────
CART_TABLE_NAME=agentcore_product_lists
CART_REGION=us-east-1
